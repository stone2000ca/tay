# Required — Tay uses OpenRouter (https://openrouter.ai) as a unified
# gateway to any LLM. One key, any model (Claude, GPT, Gemini, Llama, etc.).
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional — override the models Tay uses. Defaults below. Any model ID
# OpenRouter supports works; full catalog at https://openrouter.ai/models
# "cheap" is used for validation pings and other low-stakes calls.
# "quality" is used for voice calibration, drafting, and judging.
# OPENROUTER_MODEL_CHEAP=anthropic/claude-3.5-haiku
# OPENROUTER_MODEL_QUALITY=anthropic/claude-3.5-sonnet

# Optional — display name shown in the Tay UI. Default: "Tay".
NEXT_PUBLIC_APP_NAME=My Tay

# Auto-set by the Vercel + Supabase Marketplace integration.
# Paste manually only if running Tay outside Vercel.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Used by the auto-migrator on first server boot (lib/supabase/migrate.ts).
# The Vercel + Supabase integration sets both POSTGRES_URL (pooled) and
# POSTGRES_URL_NON_POOLING (direct). Migrations prefer the non-pooling one
# so DDL doesn't fight pgbouncer. If neither is set, the migrator silently
# skips — fine for local dev without Supabase wired.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
