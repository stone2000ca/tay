# v1.1.1: LLM API key is collected during the in-app wizard
# (/setup/llm-key) and stored encrypted in the user's own Supabase.
# Do NOT set it here. Tay supports Anthropic, OpenAI, or OpenRouter —
# the wizard auto-detects from the key prefix.
#
# The optional override below still works if you want to point an
# OpenRouter install at a different model:
# OPENROUTER_MODEL_CHEAP=anthropic/claude-3.5-haiku
# OPENROUTER_MODEL_QUALITY=anthropic/claude-3.5-sonnet

# Optional — display name shown in the Tay UI. Default: "Tay".
NEXT_PUBLIC_APP_NAME=My Tay

# Auto-set by the Vercel + Supabase Marketplace integration.
# Paste manually only if running Tay outside Vercel.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Used by the auto-migrator on first server boot (lib/supabase/migrate.ts).
# The Vercel + Supabase integration sets both POSTGRES_URL (pooled) and
# POSTGRES_URL_NON_POOLING (direct). Migrations prefer the non-pooling one
# so DDL doesn't fight pgbouncer. If neither is set, the migrator silently
# skips — fine for local dev without Supabase wired.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# v0.7 — Gmail OAuth + send path. Create an OAuth client at
# https://console.cloud.google.com/apis/credentials. App type:
# "Web application". Authorized redirect URI:
#   ${NEXT_PUBLIC_SITE_URL}/api/auth/google/callback
# Scope: https://www.googleapis.com/auth/gmail.send (no read; v0.9 adds read).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# v1.1.1 — Public URL of your Tay deployment.
# OPTIONAL: if not set, Tay falls back to:
#   VERCEL_PROJECT_PRODUCTION_URL  (auto-set on production Vercel deploys)
#   VERCEL_URL                     (auto-set on preview deploys)
#   http://localhost:3000          (local dev)
# Override only if you're using a custom domain.
NEXT_PUBLIC_SITE_URL=

# v1.1.1 — DEPRECATED env-var fallbacks. Newer Tay derives both
# secrets per-purpose via HKDF(SUPABASE_SERVICE_ROLE_KEY, instance_salt,
# info="tay-${purpose}-secret-v1"). The following are still honored as
# fallbacks if SUPABASE_SERVICE_ROLE_KEY is not yet set — useful for
# upgrades from v0.x. Once Supabase is wired, you can delete both lines.
# TAY_OAUTH_SECRET=        # legacy — used for oauth + unsubscribe secrets
# CRON_SECRET=             # legacy — used for cron route bearer
