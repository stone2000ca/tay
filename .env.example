# Required — Tay uses Claude to draft, judge, and research.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional — display name shown in the Tay UI. Default: "Tay".
NEXT_PUBLIC_APP_NAME=My Tay

# Auto-set by the Vercel + Supabase Marketplace integration.
# Paste manually only if running Tay outside Vercel.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
